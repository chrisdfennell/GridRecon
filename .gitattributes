# Normalise line endings: LF in the repo, native in the working tree.
* text=auto eol=lf

# Windows-only scripts keep CRLF so they run correctly on Windows.
*.ps1 text eol=crlf
*.bat text eol=crlf

# Binary assets — never normalise or diff as text.
*.png binary
*.jpg binary
*.der binary
*.iq  binary
*.prg binary
